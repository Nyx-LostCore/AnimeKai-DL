# App
NAME_FORMAT="{title} - S{season:02}E{episode:02} [{quality}] [{audio_codec}-{audio_channels}ch].{ext}"

UPLOAD_DIR=uploads

USE_S3=0

AUTO_DETECT_AUDIO=1

# Storage (if USE_S3=1)

S3_BUCKET=

S3_REGION=us-east-1

S3_ENDPOINT=

# Database

DATABASE_URL=sqlite:///./animekaidl.db

# Worker / Redis

REDIS_URL=redis://redis:6379/0

# Security

API_KEY=change-me

# Ongoing uploads

ONGOING_PREFIX=ongoing

ONGOING_NOTIFY=0

DISCORD_WEBHOOK_URL=

# Limits

ALLOWED_EXTENSIONS=mkv,mp4,avi,webm

MAX_UPLOAD_SIZE=2147483648